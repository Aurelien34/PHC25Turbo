; Bits map:
; For each player (1 byte each):
; - 0 Accel
; - 1 Left
; - 2 Right

INPUT_BIT_FIRE equ 0
INPUT_BIT_LEFT equ 1
INPUT_BIT_RIGHT equ 2
INPUT_BIT_START equ 3
INPUT_BIT_ESC equ 4
INPUT_BIT_GREETINGS equ 5

INPUT_VALUE_FIRE equ 1<<INPUT_BIT_FIRE
INPUT_VALUE_LEFT equ 1<<INPUT_BIT_LEFT
INPUT_VALUE_RIGHT equ 1<<INPUT_BIT_RIGHT
INPUT_VALUE_START equ 1<<INPUT_BIT_START